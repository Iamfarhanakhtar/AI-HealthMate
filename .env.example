# AI HealthMate Environment Variables

# Google Gemini API Key for AI Assistant functionality
# Get a free key at: https://aistudio.google.com/app/apikey
# IMPORTANT: When deploying to Vercel, you MUST add this exact variable
# name (VITE_GEMINI_API_KEY) in the Vercel Project Settings > Environment Variables
# and then trigger a redeployment for the app to pick it up.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the document belongs to the authenticated user
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Rules for User's private data collections
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /quizAttempts/{attemptId} {
        allow read, write: if isOwner(uid);
      }
      match /certificates/{certificateId} {
        allow read, write: if isOwner(uid);
      }
      match /bookmarks/{bookmarkId} {
        allow read, write: if isOwner(uid);
      }
      match /progress/{progressId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Rules for Feedback collection
    match /feedback/{feedbackId} {
      // Anyone can create feedback as long as they are authenticated and set themselves as the owner
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      // Users can only read or update their own feedback
      allow read, update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
  }
}
